@page
@model WorkbookModel
@{
    ViewData["Title"] = "Workbook";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Onboarding Workbook</h1>
        <p class="lead text-muted">Document your integration, reflect on your goals, and receive feedback from your manager.</p>
    </div>

    <div class="d-flex justify-content-end mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="recoverButton" onclick="recoverWorkbook()">
            <i class="fas fa-undo me-1"></i> Sync from Cloud
        </button>
    </div>

    <div class="accordion shadow-sm" id="workbookAccordion">
        @foreach (var workbookSection in Model.WorkbookSections)
        {
            var title = workbookSection.Title ?? "Untitled Section";
            var sectionId = title.Replace(" ", "");
            var savedSection = Model.SavedAnswers.ContainsKey(title) ? Model.SavedAnswers[title] : null;
            var status = savedSection?.Status ?? "Draft";

            <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
                <h2 class="accordion-header" id="heading-@sectionId">
                    <button class="accordion-button collapsed bg-light text-dark fw-semibold d-flex align-items-center justify-content-between" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@sectionId" aria-expanded="false" aria-controls="collapse-@sectionId">
                        <span class="me-auto">@title</span>
                        <span class="badge rounded-pill me-3 @(status == "Reviewed" ? "bg-success" : status == "Submitted" ? "bg-warning text-dark" : "bg-secondary")">
                            @status
                        </span>
                    </button>
                </h2>
                <div id="collapse-@sectionId" class="accordion-collapse collapse" aria-labelledby="heading-@sectionId" data-bs-parent="#workbookAccordion">
                    <div class="accordion-body bg-white border-top p-4">
                        
                        @if (savedSection != null && !string.IsNullOrEmpty(savedSection.ManagerFeedback))
                        {
                            <div class="card border-0 bg-info-subtle mb-4 rounded-3 p-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-comment-dots text-info-emphasis fa-lg me-2"></i>
                                    <strong class="text-info-emphasis me-auto">Manager Feedback</strong>
                                    @if (savedSection.FeedbackDate.HasValue)
                                    {
                                        <span class="text-muted small">@savedSection.FeedbackDate.Value.ToString("g")</span>
                                    }
                                </div>
                                <p class="card-text text-dark-emphasis mb-0 fst-italic">"@savedSection.ManagerFeedback"</p>
                            </div>
                        }

                        <form method="post">
                            <input type="hidden" name="sectionTitle" value="@title" />
                            
                            @foreach (var question in workbookSection.Questions ?? new List<string>())
                            {
                                var savedValue = savedSection?.Answers != null && savedSection.Answers.ContainsKey(question) ? savedSection.Answers[question] : "";
                                <div class="mb-4">
                                    <label class="form-label fw-medium text-secondary">@question</label>
                                    <textarea class="form-control rounded-2 border-muted" 
                                              name="answers[@question]" 
                                              data-section="@title" 
                                              data-question="@question" 
                                              rows="3" 
                                              placeholder="Type your response here...">@savedValue</textarea>
                                </div>
                            }

                            <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                                <button type="submit" name="action" value="Save" class="btn btn-outline-primary px-3 rounded-pill">
                                    <i class="fas fa-save me-1"></i> Save Draft
                                </button>
                                <button type="submit" name="action" value="Submit" class="btn btn-primary px-3 rounded-pill">
                                    <i class="fas fa-paper-plane me-1"></i> Submit to Manager
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    async function recoverWorkbook() {
        try {
            const response = await fetch('/Workbook?handler=Recover');
            if (!response.ok) {
                throw new Error('Failed to recover data');
            }
            const data = await response.json();

            for (const [sectionTitle, answers] of Object.entries(data)) {
                for (const [question, answer] of Object.entries(answers)) {
                    const input = document.querySelector(`[data-section="${sectionTitle}"][data-question="${question}"]`);
                    if (input) {
                        input.value = answer;
                    }
                }
            }
            alert('Workbook data synced successfully!');
        } catch (error) {
            console.error(error);
            alert('Failed to sync workbook data.');
        }
    }
</script>


