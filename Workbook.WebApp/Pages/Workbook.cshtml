@page
@model WorkbookModel
@{
    ViewData["Title"] = "Workbook";
}

<div class="container py-5 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">
        <div>
            <span class="hero-eyebrow"><i class="fas fa-book me-1"></i> Interactive Guide</span>
            <h1 class="hero-headline mt-2 mb-1">Onboarding Workbook</h1>
            <p class="hero-body mb-0">Document your integration, reflect on your goals, and receive feedback from your manager.</p>
        </div>
        <div>
            <button type="button" class="btn-hero-ghost" style="width: auto; padding: 0.5rem 1.1rem; font-size: 0.82rem;" id="recoverButton" onclick="recoverWorkbook()">
                <i class="fas fa-sync-alt me-2"></i> Sync from Cloud
            </button>
        </div>
    </div>

    <div class="accordion" id="workbookAccordion">
        @foreach (var workbookSection in Model.WorkbookSections)
        {
            var title = workbookSection.Title ?? "Untitled Section";
            var sectionId = title.Replace(" ", "");
            var savedSection = Model.SavedAnswers.ContainsKey(title) ? Model.SavedAnswers[title] : null;
            var status = savedSection?.Status ?? "Draft";

            <div class="accordion-item">
                <h2 class="accordion-header" id="heading-@sectionId">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@sectionId" aria-expanded="false" aria-controls="collapse-@sectionId">
                        <span class="me-auto">@title</span>
                        @if (status == "Reviewed")
                        {
                            <span class="dw-badge dw-badge-green me-3">Reviewed</span>
                        }
                        else if (status == "Submitted")
                        {
                            <span class="dw-badge dw-badge-amber me-3">Submitted</span>
                        }
                        else
                        {
                            <span class="dw-badge dw-badge-neutral me-3">Draft</span>
                        }
                    </button>
                </h2>
                <div id="collapse-@sectionId" class="accordion-collapse collapse" aria-labelledby="heading-@sectionId" data-bs-parent="#workbookAccordion">
                    <div class="accordion-body">
                        
                        @if (savedSection != null && !string.IsNullOrEmpty(savedSection.ManagerFeedback))
                        {
                            <div class="feedback-highlight mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-quote-left accent me-2"></i>
                                    <strong class="me-auto" style="color: var(--text-primary)">Manager Feedback</strong>
                                    @if (savedSection.FeedbackDate.HasValue)
                                    {
                                        <span class="text-muted small">@savedSection.FeedbackDate.Value.ToString("g")</span>
                                    }
                                </div>
                                <p class="mb-0 text-muted fst-italic">"@savedSection.ManagerFeedback"</p>
                            </div>
                        }

                        <form method="post">
                            <input type="hidden" name="sectionTitle" value="@title" />
                            
                            @foreach (var question in workbookSection.Questions ?? new List<string>())
                            {
                                var savedValue = savedSection?.Answers != null && savedSection.Answers.ContainsKey(question) ? savedSection.Answers[question] : "";
                                <div class="dw-field mb-4">
                                    <label>@question</label>
                                    <textarea class="dw-input" 
                                              name="answers[@question]" 
                                              data-section="@title" 
                                              data-question="@question" 
                                              rows="4" 
                                              placeholder="Type your response here...">@savedValue</textarea>
                                </div>
                            }

                            <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top border-secondary border-opacity-10">
                                <button type="submit" name="action" value="Save" class="btn-hero-ghost" style="width: auto;">
                                    <i class="fas fa-save me-2"></i> Save Draft
                                </button>
                                <button type="submit" name="action" value="Submit" class="btn-hero-primary" style="width: auto;">
                                    <i class="fas fa-paper-plane me-2"></i> Submit to Manager
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    async function recoverWorkbook() {
        try {
            const response = await fetch('/Workbook?handler=Recover');
            if (!response.ok) {
                throw new Error('Failed to recover data');
            }
            const data = await response.json();

            for (const [sectionTitle, answers] of Object.entries(data)) {
                for (const [question, answer] of Object.entries(answers)) {
                    const input = document.querySelector(`[data-section="${sectionTitle}"][data-question="${question}"]`);
                    if (input) {
                        input.value = answer;
                    }
                }
            }
            alert('Workbook data synced successfully!');
        } catch (error) {
            console.error(error);
            alert('Failed to sync workbook data.');
        }
    }
</script>
