@page
@model ManagerLoginModel
@{
    ViewData["Title"] = "Manager Login";
    var step = Model.Step > 0 ? Model.Step : (TempData.Peek("OtpEmail") != null ? 2 : 1);
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-12 col-sm-9 col-md-6 col-lg-5">

        <!-- Header card -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 shadow-sm"
                 style="width:72px;height:72px;background:linear-gradient(135deg,#0d6efd,#6610f2)">
                <i class="fas @(step == 2 ? "fa-key" : "fa-user-shield") fa-2x text-white"></i>
            </div>
            <h1 class="h3 fw-bold text-dark mb-1">Manager Access</h1>
            <p class="text-muted small">
                @(step == 2
                    ? "Enter the 6-digit code sent to your email."
                    : "Enter your registered team lead email to receive a one-time login code.")
            </p>
        </div>

        <!-- Progress indicator -->
        <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
            <div class="d-flex align-items-center gap-1">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold small"
                     style="width:28px;height:28px;background:@(step >= 1 ? "#0d6efd" : "#dee2e6");color:@(step >= 1 ? "white" : "#adb5bd")">1</div>
                <span class="small @(step >= 1 ? "fw-semibold text-primary" : "text-muted")">Email</span>
            </div>
            <div class="flex-grow-1" style="height:2px;background:@(step >= 2 ? "#0d6efd" : "#dee2e6");max-width:60px"></div>
            <div class="d-flex align-items-center gap-1">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold small"
                     style="width:28px;height:28px;background:@(step >= 2 ? "#0d6efd" : "#dee2e6");color:@(step >= 2 ? "white" : "#adb5bd")">2</div>
                <span class="small @(step >= 2 ? "fw-semibold text-primary" : "text-muted")">Verify OTP</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="card border-0 shadow rounded-4 p-4">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger rounded-3 py-2 px-3 small mb-3" role="alert">
                    <i class="fas fa-exclamation-circle me-1"></i> @Model.ErrorMessage
                </div>
            }

            @if (step == 1)
            {
                <!-- ── Step 1: Email Entry ── -->
                <form method="post" asp-page-handler="SendOtp">
                    <div class="mb-3">
                        <label for="Email" class="form-label fw-medium text-secondary small">Team Lead Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-envelope text-muted"></i>
                            </span>
                            <input type="email" id="Email" name="Email" class="form-control border-start-0 ps-0"
                                   placeholder="manager@company.com" value="@Model.Email" required autofocus />
                        </div>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" id="sendOtpBtn" class="btn btn-primary rounded-pill py-2 fw-semibold">
                            <i class="fas fa-paper-plane me-2"></i> Send Login Code
                        </button>
                    </div>
                </form>
            }
            else
            {
                <!-- ── Step 2: OTP Entry ── -->
                <form method="post" asp-page-handler="VerifyOtp">
                    <input type="hidden" name="Email" value="@(TempData.Peek("OtpEmail") ?? Model.Email)" />

                    <p class="text-center text-muted small mb-3">
                        Code sent to <strong>@(TempData.Peek("OtpEmail") ?? Model.Email)</strong>
                    </p>

                    <div class="mb-3">
                        <label for="OtpCode" class="form-label fw-medium text-secondary small">6-Digit Code</label>
                        <input type="text" id="OtpCode" name="OtpCode"
                               class="form-control form-control-lg text-center fw-bold rounded-3"
                               maxlength="6" inputmode="numeric" pattern="\d{6}"
                               placeholder="— — — — — —"
                               style="letter-spacing: 10px; font-size: 26px;"
                               required autofocus />
                        <div class="form-text text-center">
                            <i class="fas fa-clock me-1"></i> Code expires in 10 minutes
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" id="verifyOtpBtn" class="btn btn-success rounded-pill py-2 fw-semibold">
                            <i class="fas fa-check-circle me-2"></i> Verify & Sign In
                        </button>
                    </div>
                </form>

                <div class="text-center mt-3">
                    <a asp-page="/Auth/ManagerLogin" class="text-muted small text-decoration-none">
                        <i class="fas fa-redo me-1"></i> Request a new code
                    </a>
                </div>
            }
        </div>

        <p class="text-center mt-3 small text-muted">
            Logging in as a developer?
            <a asp-page="/Auth/Login" class="text-decoration-none fw-semibold">Regular Login</a>
        </p>

    </div>
</div>
