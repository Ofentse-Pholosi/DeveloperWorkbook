<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Dev Workbook — structured onboarding for developers joining new teams." />
    <title>@ViewData["Title"] — Dev Workbook</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Workbook.WebApp.styles.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>

<body class="@ViewData["BodyClass"]">
    <!-- ── Navbar ── -->
    <header>
        <nav class="dw-navbar navbar navbar-expand-sm">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <span class="brand-dot"></span>Dev Workbook
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Manager"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-page="/ManagerDashboard">
                                        <i class="fas fa-users-cog me-1" style="font-size:.75rem"></i>Manager View
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-page="/Dashboard">
                                        <i class="fas fa-th-large me-1" style="font-size:.75rem"></i>Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-page="/Workbook">
                                        <i class="fas fa-book-open me-1" style="font-size:.75rem"></i>My Workbook
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/About">About</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-sm-center gap-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link nav-greeting">
                                    @(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value?.Split('@')[0])
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-area="" asp-page="/Auth/Logout">
                                    <i class="fas fa-sign-out-alt me-1" style="font-size:.7rem"></i>Sign out
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/Login">Sign in</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Auth/ManagerLogin">
                                    <i class="fas fa-user-shield me-1" style="font-size:.75rem"></i>Manager
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-page="/Auth/Register">Get started</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ── Content ── -->
    <div class="dw-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ── Footer ── -->
    <footer class="dw-footer">
        <div class="dw-footer-inner">
            <span class="dw-footer-brand">Dev Workbook</span>
            <div class="dw-footer-links">
                <a href="https://github.com/Ofentse-Pholosi" target="_blank" title="GitHub">
                    <i class="fab fa-github"></i>
                </a>
                <a href="https://www.linkedin.com/in/ofentse-pholosi" target="_blank" title="LinkedIn">
                    <i class="fab fa-linkedin"></i>
                </a>
                <a href="https://www.instagram.com/ofentse.pholosi" target="_blank" title="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
