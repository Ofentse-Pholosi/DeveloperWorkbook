@page
@model IndexModel
@{
    ViewData["Title"] = "Dev Workbook — Structured onboarding for developers";
}

<!-- ── Hero ── -->
<div class="hero-shell">

    <!-- Left: Headline & CTAs -->
    <div class="hero-left">
        <p class="hero-eyebrow">
            <i class="fas fa-circle" style="font-size:.45rem;vertical-align:middle"></i>
            Structured Developer Onboarding
        </p>
        <h1 class="hero-headline">
            Your first 90 days,<br>
            <span class="accent">documented.</span>
        </h1>
        <p class="hero-body">
            Dev Workbook gives new joiners a structured space to capture learning, 
            track progress through onboarding milestones, and keep their manager 
            informed — automatically.
        </p>
        <div class="hero-cta-row">
            <a asp-page="/Auth/Register" id="getStartedBtn" class="btn-hero-primary">
                <i class="fas fa-arrow-right"></i> Start your workbook
            </a>
            <a asp-page="/About" class="btn-hero-ghost">
                See how it works
            </a>
        </div>
    </div>

    <!-- Right: Bento feature preview -->
    <div class="hero-right">
        <div class="hero-bento">

            <div class="bento-card">
                <div class="bento-icon"><i class="fas fa-book-open"></i></div>
                <p class="bento-title">Section workbook</p>
                <p class="bento-desc">Guided prompts per topic — culture, tools, codebase, team dynamics.</p>
            </div>

            <div class="bento-card">
                <div class="bento-icon"><i class="fas fa-bell"></i></div>
                <p class="bento-title">Auto-notify</p>
                <p class="bento-desc">Manager gets an email the moment you submit a section.</p>
            </div>

            <div class="bento-card">
                <div class="bento-icon"><i class="fas fa-chart-bar"></i></div>
                <p class="bento-title">Track your milestones</p>
                <p class="bento-desc">See exactly where you are across all sections at a glance.</p>
                <div class="bento-stat-row">
                    <div>
                        <div class="bento-stat-val">6</div>
                        <div class="bento-stat-label">Sections</div>
                    </div>
                    <div>
                        <div class="bento-stat-val">3</div>
                        <div class="bento-stat-label">Submitted</div>
                    </div>
                    <div>
                        <div class="bento-stat-val">1</div>
                        <div class="bento-stat-label">Reviewed</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>
