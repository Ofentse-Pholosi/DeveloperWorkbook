@page
@model ManagerReviewModel
@{
    ViewData["Title"] = $"Review: {Model.Developer.FirstName} {Model.Developer.LastName}";
}

<div class="container py-5">
    <div class="mb-4">
        <a asp-page="/ManagerDashboard" class="btn-hero-ghost" style="width: auto; padding: 0.5rem 1.1rem; font-size: 0.8rem;">
            <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
        </a>
    </div>

    <!-- Dev Info Profile Header -->
    <div class="dw-card p-4 mb-4">
        <div class="d-flex align-items-center">
            <div class="avatar-circle me-4" style="width: 64px; height: 64px; font-size: 1.25rem;">
                @Model.Developer.FirstName[0]@Model.Developer.LastName[0]
            </div>
            <div>
                <h1 class="h3 fw-bold mb-2" style="color: var(--text-primary)">Onboarding Review: @Model.Developer.FirstName @Model.Developer.LastName</h1>
                <p class="mb-0 text-muted d-flex align-items-center gap-2 flex-wrap">
                    <span class="dw-badge dw-badge-blue">@Model.Developer.DevPosition</span>
                    <span>Team: <strong style="color: var(--text-primary)">@Model.Developer.TeamName</strong></span>
                    <span class="text-secondary opacity-25">|</span>
                    <span>Division: <strong style="color: var(--text-primary)">@Model.Developer.DivisionName</strong></span>
                </p>
            </div>
        </div>
    </div>

    <!-- Sections Accordion -->
    <div class="accordion" id="reviewAccordion">
        @foreach (var workbookSection in Model.WorkbookSections)
        {
            var title = workbookSection.Title ?? "Untitled Section";
            var sectionId = title.Replace(" ", "");
            var savedSection = Model.SavedAnswers.ContainsKey(title) ? Model.SavedAnswers[title] : null;
            var status = savedSection?.Status ?? "Draft";

            <div class="accordion-item">
                <h2 class="accordion-header" id="heading-@sectionId">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@sectionId" aria-expanded="false" aria-controls="collapse-@sectionId">
                        <span class="me-auto">@title</span>
                        @if (status == "Reviewed")
                        {
                            <span class="dw-badge dw-badge-green me-3">Reviewed</span>
                        }
                        else if (status == "Submitted")
                        {
                            <span class="dw-badge dw-badge-amber me-3">Submitted</span>
                        }
                        else
                        {
                            <span class="dw-badge dw-badge-neutral me-3">Draft</span>
                        }
                    </button>
                </h2>
                <div id="collapse-@sectionId" class="accordion-collapse collapse" aria-labelledby="heading-@sectionId" data-bs-parent="#reviewAccordion">
                    <div class="accordion-body">
                        
                        <!-- Answers List -->
                        <div class="developer-responses mb-5">
                            <h3 class="h6 text-uppercase fw-bold text-muted small mb-3" style="letter-spacing:0.05em">Developer Answers</h3>
                            @foreach (var question in workbookSection.Questions ?? new List<string>())
                            {
                                var answerText = savedSection?.Answers != null && savedSection.Answers.ContainsKey(question) ? savedSection.Answers[question] : string.Empty;
                                <div class="mb-3 p-3 rounded-2" style="background:var(--bg-raised); border: 1px solid var(--border)">
                                    <div class="fw-semibold text-muted small mb-2">@question</div>
                                    @if (string.IsNullOrWhiteSpace(answerText))
                                    {
                                        <div class="text-secondary fst-italic">Not answered yet</div>
                                    }
                                    else
                                    {
                                        <div style="color: var(--text-primary); white-space: pre-wrap; font-size: 0.92rem;">@answerText</div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Feedback Form -->
                        <div class="feedback-form border-top border-secondary border-opacity-10 pt-4">
                            <h3 class="h6 text-uppercase fw-bold text-muted small mb-3" style="letter-spacing:0.05em">Manager Feedback & Sign-off</h3>
                            
                            <form asp-page-handler="SubmitFeedback" method="post">
                                <input type="hidden" name="email" value="@Model.Email" />
                                <input type="hidden" name="sectionTitle" value="@title" />
                                
                                <div class="dw-field mb-4">
                                    <label>Provide review comments, notes, or next steps:</label>
                                    <textarea class="dw-input" 
                                              name="feedbackText" 
                                              rows="4" 
                                              placeholder="Type your feedback here...">@(savedSection?.ManagerFeedback ?? string.Empty)</textarea>
                                </div>

                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                                    <div>
                                        @if (savedSection?.FeedbackDate.HasValue == true)
                                        {
                                            <span class="text-muted small">
                                                <i class="fas fa-check-circle text-success me-1"></i> Last updated: @savedSection.FeedbackDate.Value.ToString("g")
                                            </span>
                                        }
                                    </div>
                                    <button type="submit" class="btn-dw-success">
                                        <i class="fas fa-check me-2"></i> Submit & Mark Reviewed
                                    </button>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>
